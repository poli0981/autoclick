<Window x:Class="AutoClick.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:AutoClick.UI.Converters"
        xmlns:res="clr-namespace:AutoClick.UI.Resources"
        Title="AutoClick" Height="680" Width="960"
        MinHeight="500" MinWidth="750"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:StateToColorConverter x:Key="StateToColor"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tab Header -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <RadioButton x:Name="TabMain" Content="{x:Static res:Strings.Main}"
                                 IsChecked="True" Style="{StaticResource TabRadioButton}" Margin="0,0,4,0"/>
                    <RadioButton x:Name="TabSettings" Content="{x:Static res:Strings.Settings}"
                                 Style="{StaticResource TabRadioButton}" Margin="0,0,4,0"/>
                    <RadioButton x:Name="TabAbout" Content="{x:Static res:Strings.About}"
                                 Style="{StaticResource TabRadioButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <!-- Main Tab -->
            <Grid Visibility="{Binding IsChecked, ElementName=TabMain, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0" Padding="16,12" Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <Button Content="{x:Static res:Strings.AddGame}" Command="{Binding AddGameCommand}"
                                    Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                            <Button Content="{x:Static res:Strings.StartAll}" Command="{Binding StartAllCommand}"
                                    Style="{StaticResource DefaultButton}" Margin="0,0,8,0"/>
                            <Button Content="{x:Static res:Strings.StopAll}" Command="{Binding StopAllCommand}"
                                    Style="{StaticResource DangerButton}" Margin="0,0,8,0"/>
                            <Button Content="{x:Static res:Strings.RemoveAll}" Command="{Binding RemoveAllCommand}"
                                    Style="{StaticResource DangerButton}"/>

                            <!-- Scheduler -->
                            <Border Margin="12,0,0,0" Padding="0" BorderThickness="1,0,0,0"
                                    BorderBrush="{DynamicResource BorderBrush}">
                                <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                                    <TextBlock Text="{x:Static res:Strings.StartTime}" FontSize="12" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                    <TextBox Text="{Binding ScheduledStartTimeText, UpdateSourceTrigger=LostFocus}"
                                             Width="55" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"
                                             IsEnabled="{Binding IsSchedulerEnabled, Converter={StaticResource InverseBool}}"/>
                                    <TextBlock Text="{x:Static res:Strings.StopTime}" FontSize="12" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                    <TextBox Text="{Binding ScheduledStopTimeText, UpdateSourceTrigger=LostFocus}"
                                             Width="55" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"
                                             IsEnabled="{Binding IsSchedulerEnabled, Converter={StaticResource InverseBool}}"/>
                                    <Button Content="{Binding ScheduleButtonText}" Command="{Binding ToggleSchedulerCommand}"
                                            Style="{StaticResource DefaultButton}" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding SchedulerCountdown}" FontSize="12" VerticalAlignment="Center"
                                               Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold"
                                               Visibility="{Binding HasScheduler, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center">
                                <Run Text="{x:Static res:Strings.GamesRunning}"/>
                                <Run Text=": "/>
                                <Run Text="{Binding ActiveGameCount, Mode=OneWay}" FontWeight="SemiBold"
                                     Foreground="{DynamicResource PrimaryBrush}"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding GameSessions.Count, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Session Stats Bar -->
                <Border Grid.Row="1" Padding="16,6" Background="{DynamicResource BackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                        Visibility="{Binding HasStats, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,0" VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,20,0">
                            <Run Text="{x:Static res:Strings.TotalClicks}" FontWeight="Medium"/><Run Text=": "/>
                            <Run Text="{Binding TotalClicks, Mode=OneWay}" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,20,0">
                            <Run Text="{x:Static res:Strings.Uptime}" FontWeight="Medium"/><Run Text=": "/>
                            <Run Text="{Binding SessionUptime, Mode=OneWay}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,20,0">
                            <Run Text="{x:Static res:Strings.ClicksPerMin}" FontWeight="Medium"/><Run Text=": "/>
                            <Run Text="{Binding ClicksPerMinute, Mode=OneWay, StringFormat={}{0:F1}}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,0">
                            <Run Text="{x:Static res:Strings.PeakCPM}" FontWeight="Medium"/><Run Text=": "/>
                            <Run Text="{Binding PeakClicksPerMinute, Mode=OneWay}" Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold"/>
                            <Run Text=" c/m"/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Game List -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="16">
                    <ItemsControl ItemsSource="{Binding GameSessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,8"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Game Name & Status -->
                                        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="{Binding ProcessName}" FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,12,0"/>
                                            <Border CornerRadius="4" Padding="8,2" VerticalAlignment="Center"
                                                    Background="{Binding CurrentState, Converter={StaticResource StateToColor}}" Opacity="0.15">
                                                <TextBlock Text="{Binding StateText}" FontSize="11" FontWeight="Medium"
                                                           Foreground="{Binding CurrentState, Converter={StaticResource StateToColor}}"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Buttons -->
                                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="{x:Static res:Strings.AddPoint}"
                                                    Click="OnPickCoordinate" Tag="{Binding}"
                                                    Style="{StaticResource DefaultButton}" Margin="0,0,4,0"
                                                    IsEnabled="{Binding IsIdle}"
                                                    ToolTip="{x:Static res:Strings.SelectCoordinate}"/>
                                            <Button Content="{x:Static res:Strings.Random}" Click="OnRandomCoordinate" Tag="{Binding}"
                                                    Style="{StaticResource DefaultButton}" Margin="0,0,4,0"
                                                    IsEnabled="{Binding IsIdle}"/>
                                            <Button Content="{x:Static res:Strings.ClearPoints}" Click="OnClearCoordinates" Tag="{Binding}"
                                                    Style="{StaticResource DefaultButton}" Margin="0,0,4,0"
                                                    IsEnabled="{Binding IsIdle}"
                                                    Visibility="{Binding HasCoordinate, Converter={StaticResource BoolToVis}}"/>
                                            <Button Content="{x:Static res:Strings.Start}" Command="{Binding StartCommand}"
                                                    Style="{StaticResource PrimaryButton}" Margin="0,0,4,0"
                                                    Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}}"/>
                                            <Button Content="{x:Static res:Strings.Pause}" Command="{Binding PauseCommand}"
                                                    Style="{StaticResource DefaultButton}" Margin="0,0,4,0"
                                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                                            <Button Content="{x:Static res:Strings.Resume}" Command="{Binding ResumeCommand}"
                                                    Style="{StaticResource PrimaryButton}" Margin="0,0,4,0"
                                                    Visibility="{Binding IsPaused, Converter={StaticResource BoolToVis}}"/>
                                            <Button Content="{x:Static res:Strings.Stop}" Command="{Binding StopCommand}"
                                                    Style="{StaticResource DangerButton}" Margin="0,0,4,0"
                                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}"/>
                                            <Button Content="{x:Static res:Strings.ResetStats}" Command="{Binding ResetStatsCommand}"
                                                    Style="{StaticResource DefaultButton}" Margin="0,0,4,0"
                                                    Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}}"/>
                                            <Button Content="{x:Static res:Strings.RemoveGame}"
                                                    Command="{Binding DataContext.RemoveGameCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource DangerButton}"/>
                                        </StackPanel>

                                        <!-- Profile Row (Custom mode only) -->
                                        <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,4"
                                                    Visibility="{Binding IsCustomMode, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{x:Static res:Strings.Profile}" FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                                            <ComboBox x:Name="ProfileCombo" Width="160" FontSize="12" VerticalAlignment="Center"
                                                      ItemsSource="{Binding DataContext.SavedProfiles, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      DisplayMemberPath="Name" Margin="0,0,8,0"
                                                      IsEnabled="{Binding IsIdle}"/>
                                            <Button Content="{x:Static res:Strings.SaveProfile}" Click="OnSaveProfile" Tag="{Binding}"
                                                    Style="{StaticResource DefaultButton}" FontSize="11" Padding="8,3" Margin="0,0,4,0"
                                                    IsEnabled="{Binding IsIdle}"/>
                                            <Button Content="{x:Static res:Strings.LoadProfile}" Click="OnLoadProfile" Tag="{Binding}"
                                                    Style="{StaticResource DefaultButton}" FontSize="11" Padding="8,3" Margin="0,0,4,0"
                                                    IsEnabled="{Binding IsIdle}"/>
                                            <Button Content="{x:Static res:Strings.ExportProfile}" Click="OnExportProfile" Tag="{Binding}"
                                                    Style="{StaticResource DefaultButton}" FontSize="11" Padding="8,3" Margin="0,0,4,0"
                                                    IsEnabled="{Binding IsIdle}"/>
                                            <Button Content="{x:Static res:Strings.ImportProfile}" Click="OnImportProfile" Tag="{Binding}"
                                                    Style="{StaticResource DefaultButton}" FontSize="11" Padding="8,3" Margin="0,0,4,0"
                                                    IsEnabled="{Binding IsIdle}"/>
                                            <Button Content="{x:Static res:Strings.DeleteProfile}" Click="OnDeleteProfile" Tag="{Binding}"
                                                    Style="{StaticResource DangerButton}" FontSize="11" Padding="8,3"
                                                    IsEnabled="{Binding IsIdle}"/>
                                            <TextBlock Text="{x:Static res:Strings.PerGameMode}" FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="16,0,4,0"/>
                                            <ComboBox Width="90" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"
                                                      SelectedIndex="{Binding SelectedModeIndex}" IsEnabled="{Binding IsIdle}">
                                                <ComboBoxItem Content="{x:Static res:Strings.Random}"/>
                                                <ComboBoxItem Content="{x:Static res:Strings.Fixed}"/>
                                            </ComboBox>
                                            <TextBlock Text="{x:Static res:Strings.Interval}" FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                            <TextBox Text="{Binding FixedInterval, UpdateSourceTrigger=LostFocus}"
                                                     Width="45" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"
                                                     IsEnabled="{Binding IsIdle}"/>
                                            <TextBlock Text="{x:Static res:Strings.PerGameRandomMin}" FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                            <TextBox Text="{Binding PerGameRandomMin, UpdateSourceTrigger=LostFocus}"
                                                     Width="45" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"
                                                     IsEnabled="{Binding IsIdle}"/>
                                            <TextBlock Text="{x:Static res:Strings.PerGameRandomMax}" FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                            <TextBox Text="{Binding PerGameRandomMax, UpdateSourceTrigger=LostFocus}"
                                                     Width="45" FontSize="11" VerticalAlignment="Center"
                                                     IsEnabled="{Binding IsIdle}"/>
                                        </StackPanel>

                                        <!-- Info Row -->
                                        <WrapPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,4,0,0">
                                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,24,0">
                                                <Run Text="{x:Static res:Strings.Path}"/><Run Text=": "/>
                                                <Run Text="{Binding ExecutablePath, Mode=OneWay}"/>
                                            </TextBlock>
                                        </WrapPanel>
                                        <WrapPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,4,0,0">
                                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,24,0">
                                                <Run Text="{x:Static res:Strings.Coordinate}"/>
                                                <Run Text=" ("/>
                                                <Run Text="{Binding PointCount, Mode=OneWay}" FontWeight="SemiBold"/>
                                                <Run Text=" "/><Run Text="{x:Static res:Strings.Points}"/>
                                                <Run Text="): "/>
                                                <Run Text="{Binding CoordinateText, Mode=OneWay}" Foreground="{DynamicResource PrimaryBrush}"/>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,24,0"
                                                        Visibility="{Binding HasMultiplePoints, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{x:Static res:Strings.SequenceDelay}" FontSize="12" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                                <TextBox Text="{Binding SequenceDelayMs, UpdateSourceTrigger=LostFocus}"
                                                         Width="50" FontSize="12" VerticalAlignment="Center"
                                                         IsEnabled="{Binding IsIdle}"/>
                                                <TextBlock Text="ms" FontSize="12" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="4,0,0,0"/>
                                            </StackPanel>
                                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,24,0">
                                                <Run Text="{x:Static res:Strings.ClickCount}"/><Run Text=": "/>
                                                <Run Text="{Binding ClickCount, Mode=OneWay}" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            </TextBlock>
                                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,24,0">
                                                <Run Text="{x:Static res:Strings.CurrentInterval}"/><Run Text=": "/>
                                                <Run Text="{Binding LastInterval, Mode=OneWay, StringFormat={}{0:F2}}" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <Run Text="s"/>
                                            </TextBlock>
                                            <StackPanel Orientation="Horizontal"
                                                        Visibility="{Binding CanEditInterval, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{x:Static res:Strings.Interval}" FontSize="12" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                                <TextBox Text="{Binding FixedInterval, UpdateSourceTrigger=PropertyChanged}"
                                                         Width="50" FontSize="12" VerticalAlignment="Center"
                                                         IsEnabled="{Binding CanEditInterval}"/>
                                            </StackPanel>
                                        </WrapPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Log Panel -->
                <Border Grid.Row="3" Height="150" Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                        Visibility="{Binding ShowLogs, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{x:Static res:Strings.Logs}" FontWeight="SemiBold" Margin="16,8"
                                   Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"/>
                        <ListBox Grid.Row="1" x:Name="LogList" ItemsSource="{Binding LogEntries}"
                                 Background="Transparent" BorderThickness="0" FontFamily="Consolas" FontSize="11"
                                 Foreground="{DynamicResource TextSecondaryBrush}" Margin="16,0,16,8"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Settings Tab -->
            <ScrollViewer Visibility="{Binding IsChecked, ElementName=TabSettings, Converter={StaticResource BoolToVis}}"
                          VerticalScrollBarVisibility="Auto" Padding="24">
                <ContentControl x:Name="SettingsContent"/>
            </ScrollViewer>

            <!-- About Tab -->
            <ScrollViewer Visibility="{Binding IsChecked, ElementName=TabAbout, Converter={StaticResource BoolToVis}}"
                          VerticalScrollBarVisibility="Auto" Padding="24">
                <ContentControl x:Name="AboutContent"/>
            </ScrollViewer>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="16,6">
            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11">
                <Run Text="AutoClick v1.1.0"/>
                <Run Text=" | "/>
                <Run Text="{Binding GameSessions.Count, Mode=OneWay, StringFormat='{}{0} game(s)'}"/>
            </TextBlock>
        </Border>
    </Grid>
</Window>
