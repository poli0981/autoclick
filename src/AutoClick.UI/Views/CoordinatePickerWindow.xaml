<Window x:Class="AutoClick.UI.Views.CoordinatePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick Coordinate" WindowStyle="None" AllowsTransparency="True"
        Background="#01000000" Topmost="True" Cursor="Cross"
        WindowState="Maximized" ShowInTaskbar="False"
        MouseLeftButtonDown="OnMouseDown"
        PreviewKeyDown="OnKeyDown"
        Loaded="OnLoaded">

    <Grid>
        <!-- Crosshair overlay -->
        <Canvas x:Name="OverlayCanvas">
            <Line x:Name="HLine" Stroke="#FF3B82F6" StrokeThickness="1" StrokeDashArray="4,4"/>
            <Line x:Name="VLine" Stroke="#FF3B82F6" StrokeThickness="1" StrokeDashArray="4,4"/>
            <Border x:Name="CoordLabel" Background="#CC1E293B" CornerRadius="4" Padding="8,4"
                    Canvas.Left="0" Canvas.Top="0">
                <TextBlock x:Name="CoordText" Foreground="White" FontFamily="Consolas" FontSize="12"/>
            </Border>
        </Canvas>

        <!-- Instructions -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,30,0,0"
                Background="#CC1E293B" CornerRadius="8" Padding="16,8">
            <TextBlock x:Name="InstructionText"
                       Foreground="White" FontSize="14"
                       AutomationProperties.LiveSetting="Polite"/>
        </Border>
    </Grid>
</Window>
