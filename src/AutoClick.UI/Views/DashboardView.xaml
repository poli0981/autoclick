<UserControl x:Class="AutoClick.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:converters="clr-namespace:AutoClick.UI.Converters"
             xmlns:res="clr-namespace:AutoClick.UI.Resources">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <StackPanel Margin="24" MaxWidth="900">

        <!-- Action Buttons -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16" HorizontalAlignment="Right">
            <Button Content="{x:Static res:Strings.ExportStats}" Command="{Binding ExportStatsCommand}"
                    Style="{StaticResource DefaultButton}" Margin="0,0,8,0"/>
            <Button Content="{x:Static res:Strings.ResetDashboard}" Command="{Binding ResetDashboardCommand}"
                    Style="{StaticResource DangerButton}"/>
        </StackPanel>

        <!-- Summary Cards -->
        <UniformGrid Rows="1" Columns="5" Margin="0,0,0,16">
            <!-- Success -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,8,0"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.ClickSuccess}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalClicks}" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource SuccessBrush}"/>
                </StackPanel>
            </Border>
            <!-- Skipped -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,8,0"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.ClickSkipped}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding TotalSkipped}" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource WarningBrush}"/>
                </StackPanel>
            </Border>
            <!-- Uptime -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,8,0"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.Uptime}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding SessionUptime}" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </StackPanel>
            </Border>
            <!-- CPM -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,8,0"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.ClicksPerMin}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding ClicksPerMinute, StringFormat={}{0:F1}}" FontSize="28" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"/>
                </StackPanel>
            </Border>
            <!-- Peak -->
            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16,12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.PeakCPM}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock FontSize="28" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}">
                        <Run Text="{Binding PeakClicksPerMinute, Mode=OneWay}"/>
                        <Run Text=" c/m" FontSize="14" FontWeight="Normal" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- CPM Line Chart -->
        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="{x:Static res:Strings.DashboardCpmChart}" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                <lvc:CartesianChart Height="250"
                                    Series="{Binding CpmSeries}"
                                    XAxes="{Binding CpmXAxes}"
                                    YAxes="{Binding CpmYAxes}"
                                    AnimationsSpeed="00:00:00.100"
                                    TooltipPosition="Hidden"/>
            </StackPanel>
        </Border>

        <!-- Success/Skip Ratio + Per-Game Breakdown side by side -->
        <Grid Margin="0,0,0,16"
              Visibility="{Binding HasStats, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Success/Skip Ratio Pie Chart -->
            <Border Grid.Column="0" Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Visibility="{Binding HasRatioData, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.DashboardSuccessRatio}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <lvc:PieChart Height="200"
                                  Series="{Binding RatioSeries}"
                                  AnimationsSpeed="00:00:00.200"/>
                </StackPanel>
            </Border>

            <!-- Per-Game Breakdown -->
            <Border Grid.Column="2" Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.DashboardGameBreakdown}" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <lvc:CartesianChart Height="{Binding GameChartHeight}"
                                        Series="{Binding GameBreakdownSeries}"
                                        XAxes="{Binding GameXAxes}"
                                        YAxes="{Binding GameYAxes}"
                                        AnimationsSpeed="00:00:00.200"
                                        TooltipPosition="Hidden"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Per-Game CPM Timeline -->
        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                Visibility="{Binding HasStats, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="{x:Static res:Strings.DashboardGameTimeline}" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                <lvc:CartesianChart Height="200"
                                    Series="{Binding TimelineSeries}"
                                    XAxes="{Binding TimelineXAxes}"
                                    YAxes="{Binding TimelineYAxes}"
                                    AnimationsSpeed="00:00:00.100"
                                    LegendPosition="Right"/>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>
