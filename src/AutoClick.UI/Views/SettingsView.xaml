<UserControl x:Class="AutoClick.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AutoClick.UI.Converters"
             xmlns:res="clr-namespace:AutoClick.UI.Resources"
             KeyDown="OnKeyDown">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <StackPanel Margin="24" MaxWidth="600">
        <!-- Basic Section -->
        <TextBlock Text="{x:Static res:Strings.Basic}" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,16"/>

        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <StackPanel>
                <!-- Settings Mode -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static res:Strings.SettingsMode}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <ComboBox Grid.Column="1" SelectedIndex="{Binding SelectedSettingsModeIndex}"
                              IsEnabled="{Binding IsSettingsEnabled}" HorizontalAlignment="Left" Width="200">
                        <ComboBoxItem Content="{x:Static res:Strings.GlobalMode}"/>
                        <ComboBoxItem Content="{x:Static res:Strings.CustomMode}"/>
                    </ComboBox>
                </Grid>

                <!-- Click Mode -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static res:Strings.ClickMode}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <ComboBox Grid.Column="1" SelectedIndex="{Binding SelectedClickModeIndex}"
                              IsEnabled="{Binding IsGlobalParamsEnabled}" HorizontalAlignment="Left" Width="150">
                        <ComboBoxItem Content="{x:Static res:Strings.Random}"/>
                        <ComboBoxItem Content="{x:Static res:Strings.Fixed}"/>
                    </ComboBox>
                </Grid>

                <!-- Fixed Interval -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static res:Strings.Interval}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBox Grid.Column="1" Text="{Binding FixedInterval, UpdateSourceTrigger=LostFocus}"
                             Width="80" HorizontalAlignment="Left" IsEnabled="{Binding IsGlobalParamsEnabled}"/>
                </Grid>

                <!-- Random Min/Max -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static res:Strings.RandomMin}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBox Grid.Column="1" Text="{Binding RandomMin, UpdateSourceTrigger=LostFocus}"
                             Width="80" HorizontalAlignment="Left" IsEnabled="{Binding IsGlobalParamsEnabled}"/>
                </Grid>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static res:Strings.RandomMax}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBox Grid.Column="1" Text="{Binding RandomMax, UpdateSourceTrigger=LostFocus}"
                             Width="80" HorizontalAlignment="Left" IsEnabled="{Binding IsGlobalParamsEnabled}"/>
                </Grid>

                <!-- Max Games -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static res:Strings.MaxGames}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBox Grid.Column="1" Text="{Binding MaxGamesInQueue, UpdateSourceTrigger=LostFocus}"
                             Width="80" HorizontalAlignment="Left" IsEnabled="{Binding IsSettingsEnabled}"/>
                </Grid>

                <!-- Theme Toggle: Dark / Light -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static res:Strings.Theme}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <ToggleButton Grid.Column="1" IsChecked="{Binding DarkMode}" HorizontalAlignment="Left"
                                  Width="100" Height="28" Cursor="Hand">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Bg" CornerRadius="14" Background="{DynamicResource BorderBrush}" Padding="4,2">
                                                <Grid>
                                                    <TextBlock x:Name="Label" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" FontWeight="SemiBold"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="#334155"/>
                                                    <Setter TargetName="Label" Property="Text" Value="Dark"/>
                                                    <Setter TargetName="Label" Property="Foreground" Value="#F1F5F9"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="False">
                                                    <Setter TargetName="Bg" Property="Background" Value="#E2E8F0"/>
                                                    <Setter TargetName="Label" Property="Text" Value="Light"/>
                                                    <Setter TargetName="Label" Property="Foreground" Value="#0F172A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                </Grid>

                <!-- Language -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static res:Strings.Language}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <ComboBox Grid.Column="1" SelectedValue="{Binding Language}" SelectedValuePath="Tag"
                              HorizontalAlignment="Left" Width="150">
                        <ComboBoxItem Content="English" Tag="en"/>
                        <ComboBoxItem Content="Tiếng Việt" Tag="vi"/>
                        <ComboBoxItem Content="日本語" Tag="ja"/>
                        <ComboBoxItem Content="한국어" Tag="ko"/>
                        <ComboBoxItem Content="中文" Tag="zh"/>
                    </ComboBox>
                </Grid>

                <!-- Exit Behavior -->
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static res:Strings.ExitBehaviorLabel}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <ComboBox Grid.Column="1" SelectedIndex="{Binding SelectedExitBehaviorIndex}"
                              HorizontalAlignment="Left" Width="200">
                        <ComboBoxItem Content="{x:Static res:Strings.MinimizeToTray}"/>
                        <ComboBoxItem Content="{x:Static res:Strings.StopAndExit}"/>
                        <ComboBoxItem Content="{x:Static res:Strings.ForceExitLabel}"/>
                    </ComboBox>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Advanced Section -->
        <TextBlock Text="{x:Static res:Strings.Advanced}" FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,8,0,16"/>

        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <StackPanel>
                <!-- Show Logs -->
                <CheckBox Content="{x:Static res:Strings.ShowLogs}" IsChecked="{Binding ShowRealTimeLogs}"
                          Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                <!-- Auto Update -->
                <CheckBox Content="{x:Static res:Strings.AutoUpdate}" IsChecked="{Binding AutoUpdate}"
                          Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                <!-- Sound Notifications -->
                <CheckBox Content="{x:Static res:Strings.SoundNotifications}" IsChecked="{Binding SoundNotifications}"
                          Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                <!-- Game Exit Notification -->
                <CheckBox Content="{x:Static res:Strings.GameExitNotification}" IsChecked="{Binding ShowGameExitNotification}"
                          Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                <!-- Minimize on Start All -->
                <CheckBox Content="{x:Static res:Strings.MinimizeOnStartAll}" IsChecked="{Binding MinimizeOnStartAll}"
                          Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                <!-- Pixel Color Guard -->
                <TextBlock Text="{x:Static res:Strings.PixelColorGuard}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,8"/>
                <CheckBox Content="{x:Static res:Strings.EnablePixelColorGuard}" IsChecked="{Binding EnablePixelColorGuard}"
                          Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static res:Strings.ColorTolerance}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBox Grid.Column="1" Text="{Binding ColorTolerance, UpdateSourceTrigger=LostFocus}"
                             Width="80" HorizontalAlignment="Left"/>
                </Grid>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static res:Strings.OnColorMismatch}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <ComboBox Grid.Column="1" SelectedIndex="{Binding SelectedMismatchBehaviorIndex}"
                              HorizontalAlignment="Left" Width="200">
                        <ComboBoxItem Content="{x:Static res:Strings.SkipPoint}"/>
                        <ComboBoxItem Content="{x:Static res:Strings.StopSession}"/>
                        <ComboBoxItem Content="{x:Static res:Strings.WaitUntilMatch}"/>
                    </ComboBox>
                </Grid>

                <!-- Wait-until-match timeout (only when WaitUntilMatch behavior selected) -->
                <Grid Margin="0,0,0,12" Visibility="{Binding IsWaitUntilMatch, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static res:Strings.ColorWaitTimeout}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBox Text="{Binding ColorWaitTimeoutMs, UpdateSourceTrigger=LostFocus}"
                                 Width="80" HorizontalAlignment="Left"/>
                        <TextBlock Text="ms" Margin="6,0,0,0" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Grid>

                <!-- Hotkeys -->
                <TextBlock Text="{x:Static res:Strings.Hotkeys}" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,8"/>

                <!-- Pause/Resume -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static res:Strings.PauseResume}" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Border Grid.Column="1" CornerRadius="4" Padding="8,4" MinWidth="80"
                            Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <TextBlock Text="{Binding HotkeyPauseResume}" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    </Border>
                    <Button Grid.Column="2" Command="{Binding CaptureHotkeyCommand}" CommandParameter="PauseResume"
                            Style="{StaticResource DefaultButton}" Margin="8,0,0,0" Padding="8,4" IsEnabled="{Binding IsSettingsEnabled}">
                        <Button.Content>
                            <TextBlock><TextBlock.Style><Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Set"/>
                                <Style.Triggers><DataTrigger Binding="{Binding IsCapturingPauseResume}" Value="True">
                                    <Setter Property="Text" Value="Press key..."/><Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                </DataTrigger></Style.Triggers>
                            </Style></TextBlock.Style></TextBlock>
                        </Button.Content>
                    </Button>
                </Grid>

                <!-- Stop All -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static res:Strings.StopAll}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Border Grid.Column="1" CornerRadius="4" Padding="8,4" MinWidth="80"
                            Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <TextBlock Text="{Binding HotkeyStopAll}" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    </Border>
                    <Button Grid.Column="2" Command="{Binding CaptureHotkeyCommand}" CommandParameter="StopAll"
                            Style="{StaticResource DefaultButton}" Margin="8,0,0,0" Padding="8,4" IsEnabled="{Binding IsSettingsEnabled}">
                        <Button.Content>
                            <TextBlock><TextBlock.Style><Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Set"/>
                                <Style.Triggers><DataTrigger Binding="{Binding IsCapturingStopAll}" Value="True">
                                    <Setter Property="Text" Value="Press key..."/><Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                </DataTrigger></Style.Triggers>
                            </Style></TextBlock.Style></TextBlock>
                        </Button.Content>
                    </Button>
                </Grid>

                <!-- Start All -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{x:Static res:Strings.StartAll}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <Border Grid.Column="1" CornerRadius="4" Padding="8,4" MinWidth="80"
                            Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <TextBlock Text="{Binding HotkeyStartAll}" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                    </Border>
                    <Button Grid.Column="2" Command="{Binding CaptureHotkeyCommand}" CommandParameter="StartAll"
                            Style="{StaticResource DefaultButton}" Margin="8,0,0,0" Padding="8,4" IsEnabled="{Binding IsSettingsEnabled}">
                        <Button.Content>
                            <TextBlock><TextBlock.Style><Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Set"/>
                                <Style.Triggers><DataTrigger Binding="{Binding IsCapturingStartAll}" Value="True">
                                    <Setter Property="Text" Value="Press key..."/><Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                </DataTrigger></Style.Triggers>
                            </Style></TextBlock.Style></TextBlock>
                        </Button.Content>
                    </Button>
                </Grid>

                <!-- Action Buttons -->
                <WrapPanel Margin="0,8,0,0">
                    <Button Content="{x:Static res:Strings.SaveSettings}" Command="{Binding SaveSettingsCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,8"/>
                    <Button Content="{x:Static res:Strings.OpenSettingsFile}" Command="{Binding OpenSettingsFileCommand}"
                            Style="{StaticResource DefaultButton}" Margin="0,0,8,8"/>
                    <Button Content="{x:Static res:Strings.ExportLog}" Command="{Binding ExportLogCommand}"
                            Style="{StaticResource DefaultButton}" Margin="0,0,8,8"/>
                    <Button Content="{x:Static res:Strings.ExportSettings}" Command="{Binding ExportSettingsCommand}"
                            Style="{StaticResource DefaultButton}" Margin="0,0,8,8"/>
                    <Button Content="{x:Static res:Strings.ImportSettings}" Command="{Binding ImportSettingsCommand}"
                            Style="{StaticResource DefaultButton}" Margin="0,0,8,8" IsEnabled="{Binding IsSettingsEnabled}"/>
                    <Button Content="{x:Static res:Strings.ExportSession}" Command="{Binding ExportSessionCommand}"
                            Style="{StaticResource DefaultButton}" Margin="0,0,8,8"/>
                    <Button Content="{x:Static res:Strings.ImportSession}" Command="{Binding ImportSessionCommand}"
                            Style="{StaticResource DefaultButton}" Margin="0,0,8,8" IsEnabled="{Binding IsSettingsEnabled}"/>
                    <Button Content="{x:Static res:Strings.ResetAll}" Command="{Binding ResetAppCommand}"
                            Style="{StaticResource DangerButton}" Margin="0,0,8,8"/>
                </WrapPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
