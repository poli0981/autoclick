<UserControl x:Class="AutoClick.UI.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AutoClick.UI.Converters"
             xmlns:res="clr-namespace:AutoClick.UI.Resources">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Hidden">
    <StackPanel Margin="24" MaxWidth="540">

        <!-- Header -->
        <TextBlock Text="{Binding AppName}" FontSize="28" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
        <TextBlock Text="{Binding Version, StringFormat='Version {0}'}" FontSize="14"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
        <TextBlock Text="{Binding Copyright}" FontSize="11"
                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,16" Opacity="0.7"/>

        <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="14"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>

        <!-- Warnings: Anti-Cheat + AI Disclosure -->
        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8"
                BorderBrush="{DynamicResource WarningBrush}" BorderThickness="1" Opacity="0.9">
            <TextBlock Text="{x:Static res:Strings.AntiCheatWarning}" TextWrapping="Wrap" FontSize="12"
                       Foreground="{DynamicResource WarningBrush}"/>
        </Border>
        <Border Background="{DynamicResource SurfaceBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,20"
                BorderBrush="{DynamicResource TextSecondaryBrush}" BorderThickness="1" Opacity="0.85">
            <TextBlock Text="{x:Static res:Strings.AIDisclosure}" TextWrapping="Wrap" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"/>
        </Border>

        <!-- Update Section -->
        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="{x:Static res:Strings.Update}" FontWeight="SemiBold" FontSize="14"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                <TextBlock Margin="0,0,0,4" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}">
                    <Run Text="v"/><Run Text="{Binding UpdateVm.CurrentVersion, Mode=OneWay}"/>
                </TextBlock>

                <TextBlock Text="{Binding UpdateVm.StatusText}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>

                <TextBlock Text="{Binding UpdateVm.StatusText}" TextWrapping="Wrap"
                           Foreground="{DynamicResource DangerBrush}" Margin="0,0,0,8" FontSize="12"
                           Visibility="{Binding UpdateVm.HasError, Converter={StaticResource BoolToVis}}"/>

                <ProgressBar Value="{Binding UpdateVm.DownloadProgress}" Minimum="0" Maximum="100"
                             Height="6" Margin="0,0,0,8"
                             Visibility="{Binding UpdateVm.IsDownloading, Converter={StaticResource BoolToVis}}"
                             Foreground="{DynamicResource PrimaryBrush}"
                             Background="{DynamicResource SurfaceBrush}"/>

                <WrapPanel Margin="0,4,0,0">
                    <Button Content="{x:Static res:Strings.CheckForUpdate}"
                            Command="{Binding UpdateVm.CheckForUpdateCommand}"
                            Style="{StaticResource DefaultButton}" Margin="0,0,8,4"
                            IsEnabled="{Binding UpdateVm.CanCheck}"/>
                    <Button Content="{x:Static res:Strings.DownloadUpdate}"
                            Command="{Binding UpdateVm.DownloadUpdateCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,4"
                            Visibility="{Binding UpdateVm.UpdateAvailable, Converter={StaticResource BoolToVis}}"
                            IsEnabled="{Binding UpdateVm.CanDownload}"/>
                    <Button Content="{x:Static res:Strings.ApplyAndRestart}"
                            Command="{Binding UpdateVm.ApplyAndRestartCommand}"
                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,4"
                            Visibility="{Binding UpdateVm.DownloadComplete, Converter={StaticResource BoolToVis}}"
                            IsEnabled="{Binding UpdateVm.CanApply}"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Documents Section -->
        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="{x:Static res:Strings.Documents}" FontWeight="SemiBold" FontSize="14"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

                <!-- Document links -->
                <WrapPanel>
                    <Button Command="{Binding OpenLicenseCommand}" Style="{StaticResource DefaultButton}"
                            Margin="0,0,8,8" Padding="10,6" Cursor="Hand">
                        <TextBlock Text="GPL-3.0 License" FontSize="12"/>
                    </Button>
                    <Button Command="{Binding OpenPrivacyPolicyCommand}" Style="{StaticResource DefaultButton}"
                            Margin="0,0,8,8" Padding="10,6" Cursor="Hand">
                        <TextBlock Text="{x:Static res:Strings.PrivacyPolicy}" FontSize="12"/>
                    </Button>
                    <Button Command="{Binding OpenDisclaimerCommand}" Style="{StaticResource DefaultButton}"
                            Margin="0,0,8,8" Padding="10,6" Cursor="Hand">
                        <TextBlock Text="{x:Static res:Strings.Disclaimer_Label}" FontSize="12"/>
                    </Button>
                    <Button Command="{Binding OpenTermsCommand}" Style="{StaticResource DefaultButton}"
                            Margin="0,0,8,8" Padding="10,6" Cursor="Hand">
                        <TextBlock Text="{x:Static res:Strings.TermsOfService}" FontSize="12"/>
                    </Button>
                    <Button Command="{Binding OpenEulaCommand}" Style="{StaticResource DefaultButton}"
                            Margin="0,0,8,8" Padding="10,6" Cursor="Hand">
                        <TextBlock Text="{x:Static res:Strings.EULA_Label}" FontSize="12"/>
                    </Button>
                    <Button Command="{Binding OpenAcknowledgementsCommand}" Style="{StaticResource DefaultButton}"
                            Margin="0,0,8,8" Padding="10,6" Cursor="Hand">
                        <TextBlock Text="{x:Static res:Strings.Acknowledgements}" FontSize="12"/>
                    </Button>
                    <Button Command="{Binding OpenSecurityCommand}" Style="{StaticResource DefaultButton}"
                            Margin="0,0,8,8" Padding="10,6" Cursor="Hand">
                        <TextBlock Text="{x:Static res:Strings.SecurityPolicy}" FontSize="12"/>
                    </Button>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Info Cards -->
        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Developer" FontWeight="SemiBold" FontSize="14"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Developer}" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Command="{Binding OpenGitHubCommand}" Style="{StaticResource DefaultButton}"
                            Padding="8,4" Cursor="Hand">
                        <TextBlock Text="{x:Static res:Strings.ViewOnGitHub}" FontSize="11"/>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="{x:Static res:Strings.Acknowledgements}" FontWeight="SemiBold" FontSize="14"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                <TextBlock Text="{Binding ThirdParty}" TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontFamily="Consolas" FontSize="12"/>
            </StackPanel>
        </Border>

    </StackPanel>
    </ScrollViewer>
</UserControl>
