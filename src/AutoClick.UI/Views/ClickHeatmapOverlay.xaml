<Window x:Class="AutoClick.UI.Views.ClickHeatmapOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Click Heatmap" WindowStyle="None" AllowsTransparency="True"
        Background="#01000000" Topmost="True"
        ShowInTaskbar="False" ResizeMode="NoResize"
        IsHitTestVisible="False"
        Loaded="OnLoaded" Closed="OnClosed">

    <Grid>
        <Canvas x:Name="MarkerCanvas"/>

        <!-- Legend -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,12,0"
                Background="#CC1E293B" CornerRadius="6" Padding="10,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="LabelText" Foreground="White" FontSize="11" FontFamily="Consolas"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
